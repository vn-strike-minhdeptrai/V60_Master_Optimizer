#!/system/bin/sh
echo -e "Content-type: text/plain\n\n"

# ép xung cụm nhân Gold (4-6) và Prime (7) chạy ở mức hiệu năng tối đa
echo schedutil > /sys/devices/system/cpu/cpufreq/policy0/scaling_governor
echo performance > /sys/devices/system/cpu/cpufreq/policy4/scaling_governor
echo performance > /sys/devices/system/cpu/cpufreq/policy7/scaling_governor

# giam app chính CHỈ ĐƯỢC CHẠY trên 4 nhân lớn (Gold + Prime) để max FPS
echo "4-7" > /dev/cpuset/top-app/cpus

echo "gaming" > /data/local/tmp/v60_current_mode
echo "Max Hiệu năng"
